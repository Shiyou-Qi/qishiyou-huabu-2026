# ── AI 画布工作台 · 环境变量配置 ──
# 复制此文件为 .env.local 并填入对应 API Key
# ⚠️ .env.local 已加入 .gitignore，请勿在 .env 中写入真实 Key

# ── OpenAI ──
# https://platform.openai.com/api-keys
# 支持：GPT-4o / DALL·E 3 / o4-mini
OPENAI_API_KEY=

# ── DeepSeek ──
# https://platform.deepseek.com/api_keys
# 支持：DeepSeek V3 / R1
DEEPSEEK_API_KEY=

# ── 通义千问 / 万相（阿里 DashScope）──
# https://dashscope.aliyuncs.com/
# 支持：Qwen3 Max / Plus / 通义万相 2.1 / CosyVoice 2
DASHSCOPE_API_KEY=

# ── Kimi (Moonshot) ──
# https://platform.moonshot.cn/
# 支持：moonshot-v1-auto / 8k / 32k / 128k
MOONSHOT_API_KEY=

# ── 火山引擎 即梦/即梦视频（字节方舟 Ark）──
# 1. 开通模型：https://console.volcengine.com/ark/region:ark+cn-beijing/openManagement
#    → 搜索 Seedance / Seedream → 点击开通
# 2. 创建 API Key：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# 3. 填入下方
# 支持：Seedance 2.0/1.5/1.0 · Seedream 4.5/4.0
ARK_API_KEY=

# ── 智谱 GLM / CogView / CogVideo ──
# https://open.bigmodel.cn/
# 支持：GLM-4 Plus / CogView-4 / CogVideoX
ZHIPU_API_KEY=

# ── 上传文件大小限制（字节，默认 100MB = 104857600）──
NEXT_PUBLIC_MAX_UPLOAD_SIZE=104857600
